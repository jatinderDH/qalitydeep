APP_ENV=dev
QALITYDEEP_DATA_DIR=./data

# LLM backend: "openai", "anthropic" (Claude), or "ollama"
LLM_BACKEND=openai

# OpenAI (if LLM_BACKEND=openai)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1-mini

# Anthropic (Claude) – if LLM_BACKEND=anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Ollama (if LLM_BACKEND=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# LangSmith (optional, for trajectory / graph evals)
LANGSMITH_API_KEY=lsm_...
LANGSMITH_PROJECT=qalitydeep-predeploy

# Remote eval API (optional)
REMOTE_EVAL_API_URL=
REMOTE_EVAL_API_KEY=
REMOTE_EVAL_COLLECTION=qalitydeep-default

# Eval API (for playground; default localhost:8000)
EVAL_API_URL=http://localhost:8000

# DeepEval specific options if needed
DEEPEVAL_DISABLE_DOTENV=0
